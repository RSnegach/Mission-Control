# Copy to .env.local and fill in. Never commit real secrets.

# --- Mock mode ---
# When true, the app runs entirely on in-memory sample data: no Supabase, no
# Twilio, no credentials. /dashboard loads seeded calls and callbacks, and the
# Twilio webhooks work against the in-memory store. This is the only var you need
# to run locally. Everything below is ignored while MOCK_MODE=true.
MOCK_MODE=true

# --- Supabase --- (only used when MOCK_MODE is false)
# Project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Service role key. SERVER ONLY. Bypasses RLS. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=
# Anon key. Safe for the browser. Used by client-side reads once RLS is on.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Twilio ---
# Account SID (starts with AC...)
TWILIO_ACCOUNT_SID=
# Auth token. Used to validate inbound webhook signatures.
TWILIO_AUTH_TOKEN=

# --- App ---
# Public base URL Twilio will call back to. In local dev this is your ngrok https URL,
# e.g. https://abc123.ngrok-free.app  (no trailing slash)
APP_BASE_URL=http://localhost:3000

# Set to "true" to enforce Twilio signature validation on webhooks.
# Leave unset/false in early local testing, then turn on before production.
TWILIO_VALIDATE_SIGNATURE=false

# --- Auto-acknowledgment ---
# After a caller replies, an ack text is sent once, ~30s after their last message.
# The debounce window is a code constant (ACK_DEBOUNCE_MS in src/lib/template.ts).
# A short in-process interval (src/instrumentation.ts) drives the send in dev /
# single-host; on serverless that interval does not persist, so production should
# hit a sweep endpoint from a scheduled cron instead.
